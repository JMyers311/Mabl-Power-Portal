<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mabl Power Portal — Lilly Digital Core</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;450;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --ink:#0a0e1a;
  --ink-2:#10182b;
  --ink-3:#1a2438;
  --panel:#ffffff;
  --paper:#f4f6fb;
  --paper-2:#eaeef7;
  --line:#dde3f0;
  --line-2:#e8ecf5;
  --blue:#2348ff;
  --blue-2:#1734c9;
  --blue-soft:#eaeeff;
  --cyan:#06b6d4;
  --cyan-soft:#e0f7fc;
  --violet:#7c3aed;
  --violet-soft:#f1eaff;
  --green:#0f9d6e;
  --green-soft:#e3f8f0;
  --amber:#d97706;
  --amber-soft:#fdf2dd;
  --rose:#e11d48;
  --rose-soft:#fde8ee;
  --t1:#0a0e1a;
  --t2:#475069;
  --t3:#8a93ab;
  --r:14px;
  --r-sm:9px;
  --r-xs:6px;
  --mono:'JetBrains Mono',monospace;
  --disp:'Space Grotesk',sans-serif;
  --body:'Inter',system-ui,sans-serif;
  --sh-sm:0 1px 2px rgba(10,14,26,.04),0 1px 3px rgba(10,14,26,.06);
  --sh:0 2px 8px rgba(10,14,26,.05),0 8px 24px rgba(35,72,255,.05);
  --sh-lg:0 8px 28px rgba(10,14,26,.10),0 2px 8px rgba(10,14,26,.06);
}

html{scroll-behavior:smooth}
body{
  font-family:var(--body);
  background:var(--paper);
  color:var(--t1);
  font-size:14px;
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
  min-height:100vh;
}
::selection{background:var(--blue);color:#fff}

/* WIREFRAME ANNOTATION BANNER */
.wf-banner{
  background:repeating-linear-gradient(45deg,#0a0e1a,#0a0e1a 12px,#13192b 12px,#13192b 24px);
  color:#fff;padding:7px 22px;display:flex;align-items:center;justify-content:space-between;
  font-family:var(--mono);font-size:11px;letter-spacing:.5px;
}
.wf-banner b{color:#7da2ff;font-weight:700}
.wf-banner .wf-tag{background:var(--blue);padding:2px 9px;border-radius:5px;font-weight:500;color:#fff}

/* ─── TOPBAR ─── */
.topbar{
  background:rgba(255,255,255,.86);
  backdrop-filter:blur(14px);
  border-bottom:1px solid var(--line);
  height:60px;display:flex;align-items:center;justify-content:space-between;
  padding:0 22px;position:sticky;top:0;z-index:300;
}
.brand{display:flex;align-items:center;gap:11px;text-decoration:none;flex-shrink:0;cursor:pointer}
.brand-mark{
  width:34px;height:34px;border-radius:9px;flex-shrink:0;position:relative;
  background:linear-gradient(135deg,var(--blue),var(--violet));
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 12px rgba(35,72,255,.32);
}
.brand-mark span{font-family:var(--disp);font-weight:700;color:#fff;font-size:15px;letter-spacing:-1px}
.brand-mark::after{content:'';position:absolute;inset:0;border-radius:9px;border:1px solid rgba(255,255,255,.25)}
.brand-txt{display:flex;flex-direction:column;line-height:1.1}
.brand-name{font-family:var(--disp);font-weight:600;font-size:15px;letter-spacing:-.3px;color:var(--t1)}
.brand-sub{font-family:var(--mono);font-size:9.5px;color:var(--t3);letter-spacing:.4px;text-transform:uppercase}

.top-search{
  flex:1;max-width:440px;margin:0 26px;position:relative;
}
.top-search input{
  width:100%;height:40px;border:1px solid var(--line);border-radius:10px;
  background:var(--paper);padding:0 14px 0 40px;font-family:var(--body);font-size:13px;
  color:var(--t1);transition:.18s;
}
.top-search input:focus{outline:none;border-color:var(--blue);background:#fff;box-shadow:0 0 0 4px var(--blue-soft)}
.top-search input::placeholder{color:var(--t3)}
.top-search .si{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--t3);font-size:15px}
.top-search .kbd{position:absolute;right:10px;top:50%;transform:translateY(-50%);font-family:var(--mono);font-size:10px;color:var(--t3);background:#fff;border:1px solid var(--line);border-radius:5px;padding:2px 6px}

.top-actions{display:flex;align-items:center;gap:10px;flex-shrink:0}
.cta{
  background:#fff;color:var(--ink);border:1px solid var(--line);height:38px;padding:0 16px;border-radius:9px;
  font-family:var(--body);font-size:13px;font-weight:600;cursor:pointer;transition:.15s;
  display:inline-flex;align-items:center;gap:7px;text-decoration:none;
}
.cta:hover{border-color:var(--blue);color:var(--blue);background:var(--blue-soft)}
.signin{
  background:var(--ink);color:#fff;border:none;height:38px;padding:0 20px;border-radius:9px;
  font-family:var(--body);font-size:13px;font-weight:600;cursor:pointer;transition:.15s;
  display:inline-flex;align-items:center;gap:7px;flex-shrink:0;
}
.signin:hover{background:var(--blue);transform:translateY(-1px);box-shadow:0 6px 16px rgba(35,72,255,.3)}

/* ─── SHELL ─── */
.shell{display:grid;grid-template-columns:248px 1fr;min-height:calc(100vh - 60px - 32px)}

/* ─── SIDEBAR ─── */
.side{
  background:var(--ink);
  padding:18px 12px 30px;position:sticky;top:60px;height:calc(100vh - 60px);
  overflow-y:auto;
}
.side::-webkit-scrollbar{width:6px}
.side::-webkit-scrollbar-thumb{background:rgba(255,255,255,.12);border-radius:3px}
.side-grp{margin-bottom:20px}
.side-lbl{font-family:var(--mono);font-size:9.5px;font-weight:500;color:rgba(255,255,255,.38);letter-spacing:1px;text-transform:uppercase;padding:0 12px;margin-bottom:8px}
.nav-i{
  display:flex;align-items:center;gap:11px;padding:9px 12px;border-radius:9px;cursor:pointer;
  font-size:13.5px;font-weight:500;color:rgba(255,255,255,.66);transition:.14s;text-decoration:none;
  position:relative;border:1px solid transparent;
}
.nav-i:hover{background:rgba(255,255,255,.06);color:#fff}
.nav-i.active{background:linear-gradient(100deg,rgba(35,72,255,.28),rgba(124,58,237,.18));color:#fff;border-color:rgba(125,162,255,.3)}
.nav-i.active::before{content:'';position:absolute;left:-12px;top:8px;bottom:8px;width:3px;background:var(--blue);border-radius:0 3px 3px 0}
.nav-ico{width:18px;text-align:center;font-size:15px;flex-shrink:0;opacity:.9}
.nav-badge{margin-left:auto;font-family:var(--mono);font-size:9px;font-weight:700;padding:2px 7px;border-radius:20px;letter-spacing:.3px}
.nav-badge.ai{background:linear-gradient(135deg,var(--cyan),var(--blue));color:#fff}
.nav-badge.new{background:var(--green);color:#fff}
.side-div{height:1px;background:rgba(255,255,255,.07);margin:14px 10px}


.side-meta{padding:0 12px;margin-top:18px}
.side-meta-row{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:10px;color:rgba(255,255,255,.4);padding:4px 0}
.side-meta-row .pip{width:6px;height:6px;border-radius:50%;flex-shrink:0}

/* ─── MAIN ─── */
.main{padding:30px 36px;max-width:1180px}
.page{display:none;animation:fade .26s cubic-bezier(.16,1,.3,1)}
.page.show{display:block}
@keyframes fade{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

.crumb{display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:11px;color:var(--t3);margin-bottom:18px;text-transform:uppercase;letter-spacing:.5px}
.crumb b{color:var(--blue);font-weight:500}

/* ─── HERO ─── */
.hero{
  position:relative;border-radius:20px;overflow:hidden;padding:40px 42px;margin-bottom:24px;
  background:linear-gradient(120deg,var(--ink) 0%,var(--ink-2) 50%,#15214a 100%);
  color:#fff;
}
.hero-grid{position:absolute;inset:0;opacity:.5;
  background-image:linear-gradient(rgba(125,162,255,.07) 1px,transparent 1px),linear-gradient(90deg,rgba(125,162,255,.07) 1px,transparent 1px);
  background-size:32px 32px;
  -webkit-mask-image:radial-gradient(ellipse 80% 90% at 80% 10%,#000,transparent);
  mask-image:radial-gradient(ellipse 80% 90% at 80% 10%,#000,transparent);
}
.hero-glow{position:absolute;width:340px;height:340px;border-radius:50%;filter:blur(70px);opacity:.5}
.hero-glow.a{background:var(--blue);top:-130px;right:60px}
.hero-glow.b{background:var(--violet);bottom:-160px;right:280px}
.hero-in{position:relative;z-index:2;max-width:620px}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:11px;color:#7da2ff;background:rgba(125,162,255,.12);border:1px solid rgba(125,162,255,.25);padding:5px 12px;border-radius:30px;margin-bottom:18px;letter-spacing:.4px}
.hero-eyebrow .live{width:7px;height:7px;border-radius:50%;background:#4ade80;box-shadow:0 0 0 0 rgba(74,222,128,.6);animation:pulse 2s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(74,222,128,.5)}70%{box-shadow:0 0 0 8px rgba(74,222,128,0)}100%{box-shadow:0 0 0 0 rgba(74,222,128,0)}}
.hero h1{font-family:var(--disp);font-size:34px;font-weight:700;line-height:1.12;letter-spacing:-1px;margin-bottom:14px}
.hero h1 em{font-style:normal;background:linear-gradient(100deg,#7da2ff,#c4b0ff);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.hero p{font-size:15px;color:rgba(255,255,255,.72);line-height:1.6;max-width:540px}
.hero-cta{display:flex;gap:12px;margin-top:26px;flex-wrap:wrap}
.btn{font-family:var(--body);font-weight:600;font-size:13.5px;border-radius:10px;padding:11px 20px;cursor:pointer;border:none;transition:.16s;text-decoration:none;display:inline-flex;align-items:center;gap:8px}
.btn-primary{background:#fff;color:var(--ink)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 24px rgba(0,0,0,.28)}
.btn-ai{background:linear-gradient(135deg,var(--cyan),var(--blue));color:#fff}
.btn-ai:hover{transform:translateY(-2px);box-shadow:0 10px 24px rgba(35,72,255,.4)}
.btn-ghost{background:rgba(255,255,255,.08);color:#fff;border:1px solid rgba(255,255,255,.22)}
.btn-ghost:hover{background:rgba(255,255,255,.16)}

/* ─── STATS ─── */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:28px}
.stat{
  background:var(--panel);border:1px solid var(--line);border-radius:var(--r);padding:18px 20px;
  box-shadow:var(--sh-sm);transition:.18s;position:relative;overflow:hidden;
}
.stat:hover{transform:translateY(-3px);box-shadow:var(--sh);border-color:var(--line-2)}
.stat-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.stat-ico{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px}
.stat-trend{font-family:var(--mono);font-size:10px;font-weight:700;padding:3px 7px;border-radius:5px;background:var(--green-soft);color:var(--green)}
.stat-num{font-family:var(--disp);font-size:28px;font-weight:700;letter-spacing:-1px;line-height:1}
.stat-lbl{font-size:12px;color:var(--t3);margin-top:5px;font-weight:500}

/* ─── SECTION TITLES ─── */
.sec{display:flex;align-items:center;justify-content:space-between;margin:32px 0 16px}
.sec-l{display:flex;align-items:center;gap:11px}
.sec-l h2{font-family:var(--disp);font-size:19px;font-weight:600;letter-spacing:-.4px}
.sec-pill{font-family:var(--mono);font-size:10px;font-weight:500;padding:3px 10px;border-radius:20px;background:var(--blue-soft);color:var(--blue);letter-spacing:.3px}
.sec-link{font-size:12.5px;color:var(--blue);font-weight:600;text-decoration:none;display:flex;align-items:center;gap:5px}
.sec-link:hover{gap:9px}

/* ─── QUICK CARDS ─── */
.qgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.qcard{
  background:var(--panel);border:1px solid var(--line);border-radius:var(--r);padding:20px;
  text-decoration:none;display:block;box-shadow:var(--sh-sm);transition:.2s;position:relative;overflow:hidden;
}
.qcard::after{content:'↗';position:absolute;top:18px;right:18px;color:var(--t3);font-size:15px;transition:.2s;opacity:0}
.qcard:hover{transform:translateY(-4px);box-shadow:var(--sh-lg);border-color:var(--blue)}
.qcard:hover::after{opacity:1;color:var(--blue)}
.qcard-ico{width:42px;height:42px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:19px;margin-bottom:14px}
.qcard-t{font-family:var(--disp);font-size:14.5px;font-weight:600;margin-bottom:5px;color:var(--t1)}
.qcard-d{font-size:12.5px;color:var(--t3);line-height:1.5}

/* ─── CARD ─── */
.card{background:var(--panel);border:1px solid var(--line);border-radius:var(--r);padding:24px;margin-bottom:16px;box-shadow:var(--sh-sm)}
.card-h{display:flex;align-items:center;gap:13px;margin-bottom:18px}
.card-ico{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.card-t{font-family:var(--disp);font-size:15.5px;font-weight:600;letter-spacing:-.2px}
.card-s{font-size:12px;color:var(--t3);margin-top:1px}
.two{display:grid;grid-template-columns:1fr 1fr;gap:16px}

/* ─── LISTS ─── */
.list{list-style:none}
.list li{display:flex;gap:11px;padding:11px 0;border-bottom:1px solid var(--line-2);font-size:13.5px;color:var(--t2);line-height:1.55}
.list li:last-child{border-bottom:none;padding-bottom:0}
.list li::before{content:'';width:6px;height:6px;border-radius:2px;background:var(--blue);margin-top:7px;flex-shrink:0;transform:rotate(45deg)}
.list strong{color:var(--t1);font-weight:600}
.list a{color:var(--blue);text-decoration:none;font-weight:500}
.list a:hover{text-decoration:underline}
code{font-family:var(--mono);font-size:12px;background:var(--paper-2);border:1px solid var(--line);padding:1px 6px;border-radius:5px;color:var(--blue-2)}

/* ─── CALLOUT ─── */
.callout{padding:14px 16px;border-radius:11px;font-size:13px;display:flex;gap:11px;margin-bottom:18px;align-items:flex-start;line-height:1.5;border:1px solid}
.callout .ci{font-size:15px;flex-shrink:0;margin-top:1px}
.callout strong{font-weight:600}
.c-info{background:var(--blue-soft);border-color:rgba(35,72,255,.18);color:#1a2e6e}
.c-tip{background:var(--green-soft);border-color:rgba(15,157,110,.2);color:#0a5c42}
.c-warn{background:var(--amber-soft);border-color:rgba(217,119,6,.22);color:#8a4d04}

/* ─── TAGS ─── */
.tag{display:inline-flex;align-items:center;font-family:var(--mono);font-size:10.5px;font-weight:500;padding:3px 9px;border-radius:6px;letter-spacing:.2px}
.tg-blue{background:var(--blue-soft);color:var(--blue)}
.tg-green{background:var(--green-soft);color:var(--green)}
.tg-violet{background:var(--violet-soft);color:var(--violet)}
.tg-amber{background:var(--amber-soft);color:var(--amber)}
.tg-cyan{background:var(--cyan-soft);color:var(--cyan)}

/* ─── PIPELINE ─── */
.pipe{display:flex;align-items:center;gap:0;margin:18px 0;flex-wrap:wrap}
.pipe-step{background:var(--ink);color:#fff;font-family:var(--mono);font-size:12px;font-weight:500;padding:10px 18px;position:relative;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 50%,calc(100% - 12px) 100%,0 100%,12px 50%);margin-right:-6px}
.pipe-step:first-child{clip-path:polygon(0 0,calc(100% - 12px) 0,100% 50%,calc(100% - 12px) 100%,0 100%)}
.pipe-step:nth-child(1){background:var(--blue)}
.pipe-step:nth-child(2){background:var(--blue-2)}
.pipe-step:nth-child(3){background:var(--violet)}
.pipe-step:nth-child(4){background:var(--ink)}

/* ─── INTEGRATIONS ─── */
.int-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
.int{border:1px solid var(--line);border-radius:var(--r);padding:18px;background:var(--panel);box-shadow:var(--sh-sm);transition:.18s}
.int:hover{border-color:var(--blue);box-shadow:var(--sh)}
.int-top{display:flex;align-items:center;gap:12px;margin-bottom:11px}
.int-logo{width:38px;height:38px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-family:var(--disp);font-size:14px;font-weight:700;flex-shrink:0}
.int-name{font-family:var(--disp);font-size:14.5px;font-weight:600}
.int-sub{font-family:var(--mono);font-size:10.5px;color:var(--t3)}
.int-desc{font-size:12.5px;color:var(--t2);line-height:1.5}

/* ─── ACCORDION ─── */
.acc{border:1px solid var(--line);border-radius:11px;margin-bottom:10px;overflow:hidden;background:var(--panel)}
.acc-btn{width:100%;background:none;border:none;padding:15px 18px;text-align:left;font-family:var(--body);font-size:13.5px;font-weight:600;color:var(--t1);cursor:pointer;display:flex;align-items:center;justify-content:space-between;transition:.14s;gap:12px}
.acc-btn:hover{background:var(--paper)}
.acc-btn .chev{transition:.25s;color:var(--t3);font-size:12px;flex-shrink:0}
.acc-btn.open .chev{transform:rotate(180deg);color:var(--blue)}
.acc-btn .qmark{width:24px;height:24px;border-radius:7px;background:var(--amber-soft);color:var(--amber);display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0}
.acc-body{max-height:0;overflow:hidden;transition:max-height .3s ease;background:var(--panel)}
.acc-body.open{max-height:400px}
.acc-inner{padding:2px 18px 16px}

/* ─── STEP CARDS ─── */
.step{background:var(--panel);border:1px solid var(--line);border-radius:var(--r);padding:22px;margin-bottom:12px;box-shadow:var(--sh-sm);display:flex;gap:20px;align-items:flex-start;position:relative}
.step-n{width:42px;height:42px;border-radius:12px;background:var(--ink);color:#fff;font-family:var(--disp);font-size:17px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.step:nth-child(2) .step-n{background:linear-gradient(135deg,var(--blue),var(--blue-2))}
.step:nth-child(3) .step-n{background:linear-gradient(135deg,var(--cyan),var(--blue))}
.step:nth-child(4) .step-n{background:linear-gradient(135deg,var(--violet),var(--blue))}
.step:nth-child(5) .step-n{background:linear-gradient(135deg,var(--green),var(--cyan))}
.step-b{flex:1}
.step-t{font-family:var(--disp);font-size:15px;font-weight:600;margin-bottom:3px}
.step-s{font-family:var(--mono);font-size:11px;color:var(--t3);margin-bottom:13px}

.train-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:4px}
.train{border:1px solid var(--line);border-radius:11px;padding:16px;text-decoration:none;display:block;transition:.16s;background:var(--paper)}
.train:hover{border-color:var(--blue);background:#fff;transform:translateY(-2px);box-shadow:var(--sh)}
.train-lvl{font-family:var(--disp);font-size:14px;font-weight:600;margin-bottom:6px;display:flex;align-items:center;gap:7px}
.train-d{font-size:12.5px;color:var(--t2);line-height:1.45;margin-bottom:11px}
.train-link{font-size:12.5px;color:var(--blue);font-weight:600}

/* ─── RECIPE ─── */
.recipe{display:flex;flex-direction:column;gap:16px}
.rstep{display:flex;gap:16px}
.rnum{width:30px;height:30px;border-radius:50%;border:2px solid var(--blue);color:var(--blue);font-family:var(--mono);font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.rtitle{font-family:var(--disp);font-size:14px;font-weight:600;margin-bottom:3px}
.rbody{font-size:13px;color:var(--t2);line-height:1.5}
.rbody a{color:var(--blue);text-decoration:none;font-weight:600}

/* ─── META TABLE ─── */
.mtable{width:100%;border-collapse:collapse;font-size:13px}
.mtable th{background:var(--paper);font-family:var(--mono);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--t3);padding:11px 16px;text-align:left;border-bottom:1px solid var(--line)}
.mtable td{padding:12px 16px;border-bottom:1px solid var(--line-2);color:var(--t2)}
.mtable td:first-child{font-weight:600;color:var(--t1)}
.mtable tr:last-child td{border-bottom:none}
.mtable tr:hover td{background:var(--paper)}

/* ─── CONTENT STATUS (content workstream) ─── */
.content-tracker{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:8px}
.ct{background:var(--panel);border:1px solid var(--line);border-radius:11px;padding:16px;box-shadow:var(--sh-sm)}
.ct-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.ct-name{font-size:13px;font-weight:600}
.ct-bar{height:7px;background:var(--paper-2);border-radius:10px;overflow:hidden;margin-bottom:7px}
.ct-fill{height:100%;border-radius:10px;background:linear-gradient(90deg,var(--blue),var(--cyan))}
.ct-meta{font-family:var(--mono);font-size:10.5px;color:var(--t3)}

/* ─── ROADMAP (launch workstream) ─── */
.timeline{position:relative;padding-left:8px}
.tl-track{position:absolute;left:19px;top:10px;bottom:10px;width:2px;background:var(--line)}
.tl-item{display:flex;gap:18px;padding:10px 0;position:relative}
.tl-node{width:38px;height:38px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:11px;font-weight:700;z-index:2;border:3px solid var(--paper)}
.tl-done .tl-node{background:var(--green);color:#fff}
.tl-active .tl-node{background:var(--blue);color:#fff;box-shadow:0 0 0 5px var(--blue-soft)}
.tl-future .tl-node{background:#fff;color:var(--t3);border-color:var(--line)}
.tl-body{flex:1;padding-bottom:8px}
.tl-h{display:flex;align-items:center;gap:10px;margin-bottom:3px}
.tl-t{font-family:var(--disp);font-size:14px;font-weight:600}
.tl-d{font-size:12.5px;color:var(--t2);line-height:1.5}
.tl-when{font-family:var(--mono);font-size:10.5px;color:var(--t3)}

/* ─── FOOTER ─── */
.foot{border-top:1px solid var(--line);padding:16px 36px;display:flex;align-items:center;justify-content:space-between;font-size:11.5px;color:var(--t3);background:var(--panel);font-family:var(--mono);flex-wrap:wrap;gap:10px}
.foot a{color:var(--blue);text-decoration:none}
.foot-tags span{margin-right:14px}

/* ════ AI CHATBOT ════ */
.fab{
  position:fixed;bottom:26px;right:26px;z-index:400;
  width:62px;height:62px;border-radius:18px;border:none;cursor:pointer;
  background:linear-gradient(135deg,var(--cyan),var(--blue),var(--violet));
  display:flex;align-items:center;justify-content:center;font-size:26px;color:#fff;
  box-shadow:0 8px 28px rgba(35,72,255,.42);transition:.22s;
}
.fab:hover{transform:translateY(-3px) scale(1.04);box-shadow:0 14px 36px rgba(35,72,255,.55)}
.fab .fab-ping{position:absolute;top:-3px;right:-3px;background:var(--rose);color:#fff;font-family:var(--mono);font-size:9px;font-weight:700;width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:2px solid var(--paper)}

.chat-overlay{position:fixed;inset:0;background:rgba(10,14,26,.4);backdrop-filter:blur(3px);z-index:500;opacity:0;pointer-events:none;transition:.25s}
.chat-overlay.open{opacity:1;pointer-events:auto}
.chat{
  position:fixed;bottom:0;right:0;z-index:600;width:430px;max-width:100vw;height:100vh;
  background:var(--panel);box-shadow:-12px 0 40px rgba(10,14,26,.18);
  transform:translateX(105%);transition:transform .32s cubic-bezier(.16,1,.3,1);
  display:flex;flex-direction:column;
}
.chat.open{transform:translateX(0)}
.chat-head{
  background:linear-gradient(120deg,var(--ink),var(--ink-2));color:#fff;padding:18px 20px;
  display:flex;align-items:center;gap:13px;flex-shrink:0;position:relative;overflow:hidden;
}
.chat-head::after{content:'';position:absolute;width:200px;height:200px;border-radius:50%;background:radial-gradient(var(--blue),transparent 70%);opacity:.4;top:-100px;right:-40px}
.chat-bot-av{width:42px;height:42px;border-radius:12px;background:linear-gradient(135deg,var(--cyan),var(--violet));display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;position:relative;z-index:2}
.chat-bot-info{flex:1;position:relative;z-index:2}
.chat-bot-name{font-family:var(--disp);font-size:15px;font-weight:600;display:flex;align-items:center;gap:8px}
.chat-bot-status{font-family:var(--mono);font-size:10.5px;color:rgba(255,255,255,.62);display:flex;align-items:center;gap:6px;margin-top:2px}
.chat-bot-status .live{width:6px;height:6px;border-radius:50%;background:#4ade80}
.chat-x{background:rgba(255,255,255,.12);border:none;color:#fff;width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:16px;position:relative;z-index:2;transition:.15s}
.chat-x:hover{background:rgba(255,255,255,.24)}

.chat-body{flex:1;overflow-y:auto;padding:22px 20px;background:var(--paper);display:flex;flex-direction:column;gap:16px}
.chat-body::-webkit-scrollbar{width:6px}
.chat-body::-webkit-scrollbar-thumb{background:var(--line);border-radius:3px}
.msg{display:flex;gap:10px;max-width:90%;animation:msgIn .3s ease}
@keyframes msgIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.msg-av{width:30px;height:30px;border-radius:9px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:14px}
.msg.bot .msg-av{background:linear-gradient(135deg,var(--cyan),var(--violet));color:#fff}
.msg-bubble{padding:12px 15px;border-radius:13px;font-size:13.5px;line-height:1.55}
.msg.bot .msg-bubble{background:var(--panel);border:1px solid var(--line);border-top-left-radius:4px;color:var(--t1)}
.msg.user{align-self:flex-end;flex-direction:row-reverse}
.msg.user .msg-av{background:linear-gradient(135deg,var(--cyan),var(--blue));color:#fff}
.msg.user .msg-bubble{background:var(--blue);color:#fff;border-top-right-radius:4px}
.msg-bubble code{background:rgba(0,0,0,.06);border-color:transparent;color:inherit}
.msg.bot .msg-bubble strong{color:var(--blue-2)}
.msg-src{margin-top:9px;padding-top:9px;border-top:1px solid var(--line-2);display:flex;flex-wrap:wrap;gap:6px}
.msg-src-chip{font-family:var(--mono);font-size:9.5px;background:var(--blue-soft);color:var(--blue);padding:3px 8px;border-radius:20px;text-decoration:none;display:inline-flex;align-items:center;gap:4px}
.msg-src-chip:hover{background:var(--blue);color:#fff}

.typing{display:flex;gap:4px;padding:14px 16px;background:var(--panel);border:1px solid var(--line);border-radius:13px;border-top-left-radius:4px;width:fit-content}
.typing span{width:7px;height:7px;border-radius:50%;background:var(--t3);animation:bounce 1.3s infinite}
.typing span:nth-child(2){animation-delay:.18s}
.typing span:nth-child(3){animation-delay:.36s}
@keyframes bounce{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-6px);opacity:1}}

.chat-chips{padding:12px 20px 0;display:flex;flex-wrap:wrap;gap:8px;flex-shrink:0;background:var(--paper)}
.chip{font-size:12px;font-weight:500;background:var(--panel);border:1px solid var(--line);color:var(--t2);padding:8px 13px;border-radius:30px;cursor:pointer;transition:.15s}
.chip:hover{border-color:var(--blue);color:var(--blue);background:var(--blue-soft)}
.chat-input-wrap{padding:14px 20px 18px;background:var(--paper);flex-shrink:0}
.chat-input{display:flex;align-items:flex-end;gap:9px;background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:8px 8px 8px 16px;transition:.15s}
.chat-input:focus-within{border-color:var(--blue);box-shadow:0 0 0 4px var(--blue-soft)}
.chat-input textarea{flex:1;border:none;outline:none;resize:none;font-family:var(--body);font-size:13.5px;color:var(--t1);background:none;max-height:90px;line-height:1.5;padding:6px 0}
.chat-input textarea::placeholder{color:var(--t3)}
.chat-send{width:38px;height:38px;border-radius:10px;border:none;background:var(--blue);color:#fff;cursor:pointer;font-size:16px;flex-shrink:0;transition:.15s;display:flex;align-items:center;justify-content:center}
.chat-send:hover{background:var(--blue-2)}
.chat-disclaim{font-family:var(--mono);font-size:9.5px;color:var(--t3);text-align:center;margin-top:9px}

/* ─── RESPONSIVE ─── */
@media(max-width:1000px){
  .shell{grid-template-columns:1fr}
  .side{display:none}
