<script>
/* ── ROUTING ── */
function go(name,el){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('show'));
  document.querySelectorAll('.nav-i').forEach(n=>n.classList.remove('active'));
  const pg=document.getElementById('p-'+name);
  if(pg)pg.classList.add('show');
  if(el&&el.classList.contains('nav-i'))el.classList.add('active');
  else{const nv=document.querySelector('[data-nav="'+name+'"]');if(nv)nv.classList.add('active');}
  window.scrollTo({top:0,behavior:'smooth'});
}
function goName(n){go(n,null)}

/* ── ACCORDION ── */
function toggleAcc(btn){
  btn.classList.toggle('open');
  btn.nextElementSibling.classList.toggle('open');
}

/* ── CHAT ── */
const chat=document.getElementById('chat'),overlay=document.getElementById('chatOverlay'),body=document.getElementById('chatBody'),input=document.getElementById('chatInput'),chips=document.getElementById('chatChips');
function openChat(prefill){
  chat.classList.add('open');overlay.classList.add('open');
  document.querySelector('.fab').style.opacity='0';
  setTimeout(()=>{if(prefill){send(prefill)}else{input.focus()}},340);
}
function closeChat(){chat.classList.remove('open');overlay.classList.remove('open');document.querySelector('.fab').style.opacity='1'}
function autoGrow(t){t.style.height='auto';t.style.height=Math.min(t.scrollHeight,90)+'px'}

function addMsg(role,html){
  const m=document.createElement('div');m.className='msg '+role;
  m.innerHTML='<div class="msg-av">'+(role==='bot'?'✨':'DJ')+'</div><div class="msg-bubble">'+html+'</div>';
  body.appendChild(m);body.scrollTop=body.scrollHeight;return m;
}
function typing(){
  const t=document.createElement('div');t.className='msg bot';t.id='typing';
  t.innerHTML='<div class="msg-av">✨</div><div class="typing"><span></span><span></span><span></span></div>';
  body.appendChild(t);body.scrollTop=body.scrollHeight;
}
function stopTyping(){const t=document.getElementById('typing');if(t)t.remove()}

/* simulated grounded knowledge base */
const KB=[
  {k:['access','request','myaccess','editor','permission'],a:'To get Mabl access at Lilly:<br>1. Go to <strong>myAccess@Lilly</strong> and search for the <strong>Mabl Editor</strong> role.<br>2. Once granted, set up your <strong>service account</strong> and configure <strong>SSO login</strong>.<br>3. Select the correct <strong>workspace</strong> for your team before starting.',s:[['Getting Started','start'],['Request Access','start']]},
  {k:['selector','element','xpath','not found','locator','failing'],a:'For failing selectors:<br>• Retarget to <strong>stable attributes</strong> — prefer <code>id</code>, <code>data-testid</code>, or <code>aria-label</code>.<br>• Avoid auto-generated XPaths; they break on re-render.<br>• Review Mabl\'s <strong>auto-healing events</strong> in run results to spot selector drift.',s:[['Troubleshooting','troubleshoot'],['Best Practices','practices']]},
  {k:['github','actions','jenkins','gitlab','bitbucket','ci','cd','pipeline','integrat'],a:'Mabl supports <strong>Jenkins, GitHub Actions, GitLab CI, and Bitbucket</strong>. For GitHub Actions, use the official Mabl Action in your workflow YAML — results post back to PR checks automatically. The standard pipeline is: <strong>Lint → Deploy to Test → Run Mabl Plans → Report</strong>, and you should fail the pipeline on plan failures to enforce quality gates.',s:[['Integrations','integrations']]},
  {k:['naming','convention','branch','wip','master'],a:'Naming & branching standards:<br>• Use the <strong>master</strong> branch unless versioning requires otherwise.<br>• Name WIP tests as <code>WIP – [App] – [Feature] – [Test]</code>.<br>• Tag & disable WIP tests until reviewed; add to plans only when finalized.<br>• Link tests to Jira work items for traceability.',s:[['Best Practices','practices']]},
  {k:['wait','slow','timing','speed','flaky'],a:'Before adding waits, always adjust the <strong>Unified Runner page interaction speed</strong> first — explicit waits should be a last resort. For slow-loading elements, use Mabl\'s <strong>wait-for-element</strong> condition rather than fixed waits.',s:[['Troubleshooting','troubleshoot']]},
  {k:['xray','traceability','evidence'],a:'Sync Mabl results to <strong>xRay</strong> for step-level evidence and full traceability. Important: ensure test cases are <strong>unlocked</strong> in xRay before pushing results.',s:[['Integrations','integrations']]},
  {k:['training','certif','university','foundation','learn'],a:'Mabl University offers two tracks: <strong>Foundations</strong> (core concepts, trainer browser, test creation) and <strong>Advanced</strong> (data tables, plan variables, API testing, integrations). Both are linked on the Getting Started page.',s:[['Getting Started','start']]},
];
function answer(q){
  const lq=q.toLowerCase();
  let best=null,score=0;
  KB.forEach(e=>{const hits=e.k.filter(k=>lq.includes(k)).length;if(hits>score){score=hits;best=e}});
  if(best&&score>0){
    let src='<div class="msg-src">'+best.s.map(s=>'<a class="msg-src-chip" onclick="go(\''+s[1]+'\',null);closeChat()">📄 '+s[0]+'</a>').join('')+'</div>';
    return best.a+src;
  }
  return 'I don\'t have a confident answer grounded in the portal docs for that one. I\'d recommend escalating to <strong>Mabl Support</strong> (24/5) or posting on <strong>Stack Overflow Enterprise</strong> with the <code>mabl</code> tag.<div class="msg-src"><a class="msg-src-chip" onclick="go(\'troubleshoot\',null);closeChat()">🆘 Getting Help</a></div>';
}
function send(text){
  const q=(text||input.value).trim();if(!q)return;
  addMsg('user',q.replace(/</g,'&lt;'));
  input.value='';input.style.height='auto';
  if(chips)chips.style.display='none';
  typing();
  setTimeout(()=>{stopTyping();addMsg('bot',answer(q))},900+Math.random()*500);
}
